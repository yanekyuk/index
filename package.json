{
  "name": "index-monorepo",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:evaluator": "cd evaluator && bun run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:protocol": "cd protocol && bun run dev",
    "build": "bun run build:protocol && bun run build:frontend",
    "build:frontend": "cd frontend && bun install && bun run build",
    "build:protocol": "cd protocol && bun install && bun run build",
    "start": "bun run start:protocol & bun run start:frontend",
    "start:frontend": "cd frontend && bun run start",
    "start:protocol": "cd protocol && bun run start",
    "lint": "cd frontend && bun run lint && cd ../protocol && bun run lint",
    "test": "cd protocol && bun test",
    "worktree:setup": "bash scripts/worktree-setup.sh",
    "worktree:list": "bash scripts/worktree-list.sh",
    "worktree:dev": "bash scripts/worktree-dev.sh",
    "worktree:build": "bash scripts/worktree-build.sh"
  },
  "devDependencies": {
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "protocol/src/**/*.ts": "bash -c 'cd protocol && bunx eslint --no-warn-ignored \"$@\"' --",
    "frontend/src/**/*.{ts,tsx}": "bash -c 'cd frontend && bunx eslint --no-warn-ignored \"$@\"' --"
  }
}
