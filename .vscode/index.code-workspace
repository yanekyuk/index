{
    // This workspace file provides a basic multi-root setup for the Index project.
    // Files such as tasks.json will be ignored and developers can implement their own freely.
    "folders": [
        {
            "name": "Index",
            "path": "../"
        },
        {
            "name": "Frontend",
            "path": "../frontend"
        },
        {
            "name": "Protocol",
            "path": "../protocol"
        },
        {
            "name": "Evaluator",
            "path": "../evaluator"
        },
        {
            "name": "Worktrees",
            "path": "../.worktrees"
        }
    ],
    "settings": {
        "workbench.colorTheme": "Claude Dark",
        "workbench.iconTheme": "material-icon-theme",
        "editor.fontFamily": "'JetBrains Mono', 'IBM Plex Mono','Fira Code','Source Code Pro', monospace",
        "editor.fontLigatures": true,
        "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'IBM Plex Mono', monospace",
        "terminal.integrated.fontLigatures.enabled": true,
        // Map specific Root Folder Names (case-sensitive) to Icon Names
        "material-icon-theme.rootFolders.associations": {
            "Index": "core", // Maps "Index" to the 'core' icon
            "Frontend": "client", // Maps "Frontend" to the 'client' icon
            "Protocol": "api", // Maps "Protocol" to the 'api' icon
            "Evaluator": "test",
            "Worktrees": "git"
        },
        "material-icon-theme.folders.associations": {
            "protocol": "core",
            "agents": "robot",
            "graphs": "api",
            "profile": "public",
            "intent": "lib",
            "opportunity": "event",
            "adapters": "database",
            "index": "public",
            "smartest": "test",
        },
        "claudeCode.preferredLocation": "sidebar"
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Index",
                "type": "shell",
                "command": "/bin/zsh",
                "isBackground": true,
                "options": { "cwd": "${workspaceFolder:Index}" },
                "runOptions": { "runOn": "folderOpen" },
                "presentation": {
                    "echo": false,
                    "reveal": "always",
                    "panel": "dedicated"
                }
            },
            {
                "label": "Frontend",
                "type": "shell",
                "command": "/bin/zsh",
                "isBackground": true,
                "options": { "cwd": "${workspaceFolder:Frontend}" },
                "runOptions": { "runOn": "folderOpen" },
                "presentation": {
                    "echo": false,
                    "reveal": "always",
                    "panel": "dedicated"
                }
            },
            {
                "label": "Protocol",
                "type": "shell",
                "command": "/bin/zsh",
                "isBackground": true,
                "options": { "cwd": "${workspaceFolder:Protocol}" },
                "runOptions": { "runOn": "folderOpen" },
                "presentation": {
                    "echo": false,
                    "reveal": "always",
                    "panel": "dedicated"
                }
            },
            {
                "label": "Evaluator",
                "type": "shell",
                "command": "/bin/zsh",
                "isBackground": true,
                "options": { "cwd": "${workspaceFolder:Evaluator}" },
                "runOptions": { "runOn": "folderOpen" },
                "presentation": {
                    "echo": false,
                    "reveal": "always",
                    "panel": "dedicated"
                }
            },
            {
                "label": "Open workspace terminals",
                "dependsOn": ["Index", "Frontend", "Protocol", "Evaluator"],
                "runOptions": { "runOn": "folderOpen" }
            }
        ]
    }
}