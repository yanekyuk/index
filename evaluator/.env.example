# Protocol API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# PostgreSQL (evaluator's own database)
DATABASE_URL=postgresql://postgres:password@localhost:5433/evaluator_dev

# PostgreSQL (protocol's database — used for seeding test data during eval runs)
PROTOCOL_DATABASE_URL=postgresql://postgres:password@localhost:5432/protocol_dev

# Auth is handled by the protocol server's Better Auth instance
# No auth secrets needed here -- evaluator validates sessions via protocol API

# Origin for server-side auth fetch (Better Auth requires it)
# Local: http://localhost:3002 | Railway: https://evaluator-dev.up.railway.app
EVALUATOR_ORIGIN=http://localhost:3002

# OpenRouter for evaluation LLMs (simulated user, need fulfillment scorer)
OPENROUTER_API_KEY=your-openrouter-api-key
