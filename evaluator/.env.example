# Protocol API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# PostgreSQL (evaluator's own database)
DATABASE_URL=postgresql://postgres:password@localhost:5433/evaluator_dev

# Privy (same app as frontend, add evaluator origin to allowed list)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_PRIVY_CLIENT_ID=your-privy-client-id
PRIVY_APP_SECRET=your-privy-app-secret

# OpenRouter for evaluation LLMs (simulated user, need fulfillment scorer)
OPENROUTER_API_KEY=your-openrouter-api-key
