DATABASE_URL="postgresql://username:password@localhost:5432/protocol_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
OPENAI_API_KEY="your-openai-api-key-here"
TAVILY_API_KEY="your-tavily-api-key-here"
RESEND_API_KEY="your-resend-api-key-here" 

# Crawl4AI service (used for index links crawling)
CRAWL4AI_BASE_URL="http://crawl4ai.env-dev:11235"
# Optional tuning (defaults shown)
# CRAWL4AI_FEWSHOT_MODE=always   # always|fallback|never (server call uses instruction; fallback handled in tests)
# CRAWL4AI_FEWSHOT_ALL_PATTERNS=true
# CRAWL4AI_LLM_PROVIDER=openai/gpt-4o
# CRAWL4AI_DELAY_S=3
# CRAWL4AI_SCAN_FULL_PAGE=false
# CRAWL4AI_SIMULATE_USER=true
# CRAWL4AI_REMOVE_OVERLAY=true
# CRAWL4AI_MAGIC=true
# CRAWL4AI_TIMEOUT_MS=120000

# Langfuse Integration
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key-here"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key-here"
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Composio Integration
COMPOSIO_API_KEY=your_composio_api_key_here 

# Unified Sync
# Use DB-backed run store by default (set to 0 to disable)
SYNC_USE_DB_STORE=1
# Max concurrent sync jobs
SYNC_CONCURRENCY=2
# Optional default user for CLI
# SYNC_USER_ID=

# Gmail Integration
# Sent Mail is always indexed. To also index the Inbox (received mail),
# set GMAIL_INCLUDE_RECEIVED to true. Default is false.
GMAIL_INCLUDE_RECEIVED=false
