########################################
# Required
########################################

# Postgres connection
DATABASE_URL=postgresql://username:password@localhost:5432/protocol_db

# OpenRouter for LLM features (agents, intent generation)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Required OpenRouter Presets (create at https://openrouter.ai/settings/presets):
# - intent-inferrer: Complex structured output generation from content
# - intent-summarizer: Text summarization with length constraints
# - intent-tag-suggester: Tag/cluster generation from intent analysis
# - intent-indexer: Intent appropriateness evaluation scoring
# - vibe-checker: Collaboration synthesis generation
# - intro-maker: Email introduction generation
# - semantic-relevancy: Semantic intent relationship analysis

# Privy authentication (server)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Server
PORT=3001                 # default: 3001
NODE_ENV=development      # default: development

########################################
# Optional (defaults shown)
########################################

# Email (Resend). If not set, emails are skipped.
# RESEND_API_KEY=

# Redis cache. Use REDIS_URL or individual fields (default localhost:6379, db=0).
# REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Unstructured API (document parsing). If not set, some file types are disabled.
# UNSTRUCTURED_API_URL=

# Uploads storage root. Default: ./uploads relative to API CWD (protocol/uploads in dev); served at /uploads.
# Example: /var/data/index/uploads or ./data/uploads
# UPLOADS_ROOT=

# Crawl4AI (web crawling for Index Links)
CRAWL4AI_BASE_URL=http://localhost:11235
# CRAWL4AI_TIMEOUT_MS=120000
# CRAWL4AI_MAX_DEPTH=1
# CRAWL4AI_MAX_PAGES=50
# CRAWL4AI_CONCURRENCY=4

# Proxy configuration for web crawling
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=your-proxy-username
# PROXY_PASSWORD=your-proxy-password

# Composio (3rd‑party integrations like Gmail/Notion/Slack)
# If not set, integrations are disabled gracefully.
# COMPOSIO_API_KEY=

# Composio Auth Config IDs (optional - will use toolkit.authorize default if not set)
# These are used to specify custom OAuth configurations for each integration
# COMPOSIO_AUTH_CONFIG_SLACK=
# COMPOSIO_AUTH_CONFIG_NOTION=
# COMPOSIO_AUTH_CONFIG_DISCORD=
# COMPOSIO_AUTH_CONFIG_AIRTABLE=
# COMPOSIO_AUTH_CONFIG_GMAIL=
# COMPOSIO_AUTH_CONFIG_GOOGLECALENDAR=

# Langfuse (tracing/observability)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Links sync behavior
# LINKS_SYNC_TRIGGER_BROKERS=false   # default: false (do not trigger brokers on sync)

# Queue system configuration
# QUEUE_CONCURRENCY=3                # default: 3 (total number of workers)
# QUEUE_POLL_INTERVAL_MS=100         # default: 100ms (job polling frequency)
# QUEUE_MAX_USERS=10                 # default: 10 (max concurrent users)
# QUEUE_MAX_WORKERS_PER_USER=3       # default: 3 (max workers per user)

# AWS S3 (currently unused; keep if you plan to enable S3 uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION=
# AWS_S3_BUCKET=

########################################
# Deprecated / Ignored
########################################

# JWT is not used; Privy provides auth.
# JWT_SECRET=
# JWT_EXPIRES_IN=
