{
  "watch": ["src"],
  "ext": "ts,json",
  "ignore": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "dist/**/*",
    "node_modules/**/*",
    "uploads/**/*",
    "tests/**/*",
    "drizzle/**/*",
    "*.log"
  ],
  "exec": "node -r ts-node/register src/index.ts",
  "env": {
    "NODE_ENV": "development",
    "TS_NODE_TRANSPILE_ONLY": "true",
    "TS_NODE_FILES": "true"
  },
  "delay": 1000,
  "verbose": false,
  "legacyWatch": false
} 