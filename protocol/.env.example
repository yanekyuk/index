########################################
# 1. Core
########################################

# Postgres connection
DATABASE_URL=postgresql://username:password@localhost:5432/protocol_db

# Server
PORT=3001
NODE_ENV=development

# Protocol base URL for auth, OAuth callbacks, email links. Use HTTPS in production.
# BASE_URL=https://protocol.dev.index.network

# Frontend URL (for notification links, integration OAuth callbacks)
# FRONTEND_URL=https://index.network


########################################
# 2. Authentication
########################################

# Better Auth (self-hosted authentication)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth (leave empty to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Comma-separated list of trusted origins for CORS
# TRUSTED_ORIGINS=http://localhost:5173


########################################
# 3. LLM / AI (OpenRouter)
########################################

# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Chat agent model (default: google/gemini-3-pro-preview)
# CHAT_MODEL=google/gemini-3-pro-preview
# CHAT_REASONING_EFFORT=low   # minimal | low | medium | high | xhigh

# Opportunity evaluation mode (experimental: fire one LLM call per candidate in parallel)
# RUN_OPPORTUNITY_EVAL_IN_PARALLEL=false

# Embeddings (default: openai/text-embedding-3-large, 2000 dims)
# EMBEDDING_MODEL=openai/text-embedding-3-large
# EMBEDDING_DIMENSIONS=2000

# Smartest test framework (LLM verifier/generator overrides)
# SMARTEST_VERIFIER_MODEL=google/gemini-2.5-flash
# SMARTEST_GENERATOR_MODEL=google/gemini-2.5-flash


########################################
# 4. Redis
########################################

# Used for BullMQ job queues and cache. Default: localhost:6379, db 0.
# REDIS_URL=                   # Full URL (overrides individual settings below)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0


########################################
# 5. Messaging (XMTP)
########################################

# Required for messaging. Must not change once users have messaging;
# key mismatch is auto-recovered by removing local DB.
WALLET_ENCRYPTION_KEY=your-64-char-hex-string-32-bytes
XMTP_ENV=dev


########################################
# 6. Storage (S3-compatible)
########################################

# Avatars, feedback images. Served via presigned URLs through /api/storage/*
# Railway buckets use https://t3.storageapi.dev as endpoint and region=auto
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# PRESIGNED_URL_EXPIRATION_SECONDS=3600


########################################
# 7. Email (Resend)
########################################

# If not set, emails are skipped.
# RESEND_API_KEY=
# ENABLE_EMAIL_TESTING=true
# TESTING_EMAIL_ADDRESS=


########################################
# 8. Integrations
########################################

# Composio (Gmail, Notion, Slack, Airtable, Google Docs)
# If not set, integrations are disabled.
# COMPOSIO_API_KEY=
# COMPOSIO_CALLBACK_URL=      # OAuth callback; falls back to FRONTEND_URL

# Unstructured API (document parsing). If not set, some file types are disabled.
# UNSTRUCTURED_API_URL=

# Parallels API (web crawling and profile extraction for links)
# PARALLELS_API_KEY=


########################################
# 9. Observability
########################################

# Langfuse (LLM tracing)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Sentry (error tracking)
# SENTRY_DSN=

# Logging
# LOG_LEVEL=debug              # debug (dev default) | info (prod default) | warn | error
# LOG_FILTER=                  # Filter log output by pattern

# Debug API (enables /api/debug/* endpoints)
# ENABLE_DEBUG_API=false

# Bull Board UI port (default: same as PORT)
# ADMIN_QUEUES_PORT=3001
