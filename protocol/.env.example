########################################
# Required
########################################

# Postgres connection
DATABASE_URL=postgresql://username:password@localhost:5432/protocol_db

# OpenRouter for LLM and embeddings (agents, intent generation, semantic search)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Required OpenRouter Presets (create at https://openrouter.ai/settings/presets):
# - intent-inferrer: Complex structured output generation from content
# - intent-summarizer: Text summarization with length constraints
# - intent-tag-suggester: Tag/cluster generation from intent analysis
# - intent-indexer: Intent appropriateness evaluation scoring
# - vibe-checker: Collaboration synthesis generation
# - intro-maker: Email introduction generation
# - semantic-relevancy: Semantic intent relationship analysis
# - intent-freshness-auditor: Intent expiration detection based on temporal markers
# - hyde-generator: Hypothetical document generation for opportunity matching

# Privy authentication (server)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Stream Chat (required for direct messaging / chat)
STREAM_API_KEY=your-stream-api-key
STREAM_SECRET=your-stream-secret

# Server
PORT=3001
NODE_ENV=development

# API base URL (for email links, unsubscribe). Must include /api path.
# API_URL=http://localhost:3001/api

# Frontend origin (for CORS). If unset, localhost/127.0.0.1 origins are reflected.
# FRONTEND_URL=http://localhost:3000

########################################
# Optional (defaults shown)
########################################

# Embeddings (default: OpenRouter + openai/text-embedding-3-large, 2000 dims)
# EMBEDDING_MODEL=openai/text-embedding-3-large
# EMBEDDING_DIMENSIONS=2000

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Smartest test framework (LLM verifier/generator overrides)
# SMARTEST_VERIFIER_MODEL=google/gemini-2.5-flash
# SMARTEST_GENERATOR_MODEL=google/gemini-2.5-flash

# Email (Resend). If not set, emails are skipped.
# RESEND_API_KEY=
# ENABLE_EMAIL_TESTING=true
# TESTING_EMAIL_ADDRESS=

# Redis (default: localhost:6379, db=0). Used for queues and cache.
# REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Unstructured API (document parsing). If not set, some file types are disabled.
# UNSTRUCTURED_API_URL=

# Uploads storage root. Default: ./uploads; served at /uploads.
# UPLOADS_ROOT=

# Parallels API (web crawling and profile extraction for links)
# PARALLELS_API_KEY=

# Composio (Gmail/Notion/Slack/Airtable/Google Docs). If not set, integrations disabled.
# COMPOSIO_API_KEY=
# COMPOSIO_AUTH_CONFIG_SLACK=
# COMPOSIO_AUTH_CONFIG_NOTION=
# COMPOSIO_AUTH_CONFIG_DISCORD=
# COMPOSIO_AUTH_CONFIG_AIRTABLE=
# COMPOSIO_AUTH_CONFIG_GOOGLEDOCS=

# Langfuse (LLM tracing)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Sentry (error tracking)
# SENTRY_DSN=

# Links sync: set true to trigger context brokers when links are synced
# LINKS_SYNC_TRIGGER_BROKERS=false

# S3-compatible storage (avatars, feedback)
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Admin: Bull Board UI port (default: same as PORT)
# ADMIN_QUEUES_PORT=3001
