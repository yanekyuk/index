    "@privy-io/server-auth": "^1.26.1",
    "@sentry/node": "^10.29.0",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.6.0",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.36.4",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.6.1",
    "isomorphic-dompurify": "^2.33.0",
