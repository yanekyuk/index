{
  "name": "protocol",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "nodemon --inspect",
    "dev:prod": "NODE_ENV=production nodemon --inspect",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/db-seed.ts",
    "db:flush": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/db-flush.ts",
    "maintenance:trigger-integration": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/trigger-integration.ts",
    "maintenance:export-slack": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/export-slack.ts",
    "maintenance:import-slack-export": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/import-slack-export.ts",
    "maintenance:reset-brokers": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/reset-brokers.ts",
    "maintenance:update:embeddings": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/update-embeddings.ts",
    "integration-worker": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/integration-worker.ts",
    "social-worker": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/social-worker.ts",
    "audit-freshness": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register ./src/cli/audit-intent-freshness.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.939.0",
