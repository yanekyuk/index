    "node-html-markdown": "^2.0.0",
    "openai": "^4.103.0",
    "parallel-web": "^0.2.4",
    "postgres": "^3.4.7",
    "resend": "^4.0.1",
    "snowflake-sdk": "^1.9.2",
    "timeago.js": "^4.0.2",
    "unstructured-client": "^0.27.0",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
