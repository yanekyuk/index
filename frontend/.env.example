# Protocol server URL (server-side only, used by Next.js rewrites to proxy /api/* requests)
# Default: http://localhost:3001 (no need to set in local dev)
# PROTOCOL_URL=http://localhost:3001

# S3 (optional)
# S3_ENDPOINT=https://t3.storageapi.dev
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# BUTTONDOWN_API_KEY=