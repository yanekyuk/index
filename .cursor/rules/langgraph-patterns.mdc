## Common Anti-Patterns

### ❌ Linear Graph (No Conditionals)

```typescript
// ❌ BAD - No conditional routing, just use service calls
workflow
  .addEdge(START, "step1")
  .addEdge("step1", "step2")
  .addEdge("step2", "step3")
  .addEdge("step3", END);

// Use this instead:
async function processIntent(input) {
  const step1Result = await agent1.invoke(input);
  const step2Result = await agent2.invoke(step1Result);
  return await agent3.invoke(step2Result);
}
```

### ❌ Throwing Errors in Nodes

```typescript
// ❌ BAD - Throwing errors breaks the graph
const node = async (state) => {
  if (!state.data) {
    throw new Error("Missing data");  // Don't do this
  }
};

// ✅ GOOD - Return error state
const node = async (state) => {
  if (!state.data) {
    log.error("[Node] Missing required data");
    return { error: "Missing data" };
  }
};
```

### ❌ Hardcoded Dependencies

```typescript
// ❌ BAD - Creating dependencies inside graph
const workflow = new StateGraph(MyState)
  .addNode("process", async (state) => {
    const db = new Database();  // Don't do this
    return await db.query(state.id);
  });

// ✅ GOOD - Inject via factory
class MyGraphFactory {
  constructor(private database: Database) {}
  
  private buildGraph() {
    return new StateGraph(MyState)
      .addNode("process", async (state) => {
        return await this.database.query(state.id);
      });
  }
}
```

