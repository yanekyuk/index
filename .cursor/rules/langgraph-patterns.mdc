## Testing Graphs

### Test Structure

```typescript
import { describe, it, expect, beforeEach } from 'bun:test';
import { IntentGraphFactory } from './intent.graph';
import { MockDatabase } from '../../../test-utils/mock-database';

describe('IntentGraph', () => {
  let factory: IntentGraphFactory;
  let mockDb: MockDatabase;
  
  beforeEach(() => {
    mockDb = new MockDatabase();
    factory = new IntentGraphFactory(mockDb);
  });
  
  it('should skip inference for delete operations', async () => {
    const graph = factory.createGraph();
    
    const result = await graph.invoke({
      userId: 'user-1',
      inputContent: null,
      operationMode: 'delete',
      targetIntentIds: ['intent-1']
    });
    
    expect(result.actions).toHaveLength(1);
    expect(result.actions[0].type).toBe('expire');
    expect(result.inferredIntents).toBeUndefined(); // Inference skipped
  });
  
  it('should use fast path for query operations', async () => {
    // Test conditional routing by checking state at different nodes
  });
});
```

