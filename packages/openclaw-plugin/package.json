{
  "name": "@indexnetwork/openclaw-plugin",
  "version": "0.21.0",
  "description": "Index Network — OpenClaw plugin. Find the right people and let them find you.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "openclaw.plugin.json",
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc -p src/tests/tsconfig.json",
    "test": "bun test src/tests",
    "test:watch": "bun test --watch src/tests",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "runtimeExtensions": ["./dist/index.js"],
    "compat": {
      "openclaw": ">=0.1.0"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
