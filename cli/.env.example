# ── Environment ──────────────────────────────────────────────────────
# Sets URL defaults. When "production", defaults to index.network hosts.
# When omitted or "development", defaults to localhost.
NODE_ENV=development

# ── URL Overrides (optional) ─────────────────────────────────────────
# Override the protocol API URL. Defaults based on NODE_ENV:
#   development → http://localhost:3001
#   production  → https://api.index.network
NDX_API_URL=

# Override the frontend app URL. Defaults based on NODE_ENV:
#   development → http://localhost:3000
#   production  → https://index.network
NDX_APP_URL=
