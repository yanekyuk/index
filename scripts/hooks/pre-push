#!/usr/bin/env bash
# Regenerates SKILL.md files when pushing dev/main to indexnetwork/index.
# Subtree sync to consuming repos runs in CI now —
# see .github/workflows/sync-subtrees.yml.

is_indexnetwork_remote() {
  local remote_url="$1"

  [[ "$remote_url" =~ ^git@github\.com:indexnetwork/index/?(\.git)?$ ]] ||
    [[ "$remote_url" =~ ^https://github\.com/indexnetwork/index/?(\.git)?$ ]] ||
    [[ "$remote_url" =~ ^ssh://git@github\.com(:22)?/indexnetwork/index/?(\.git)?$ ]]
}

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  remote_name="$1"
  remote_url="$(git remote get-url --push "$remote_name" 2>/dev/null || true)"

  # Only run when pushing to the canonical indexnetwork/index repository.
  is_indexnetwork_remote "$remote_url" || continue

  case "$remote_ref" in
    refs/heads/dev)
      target_branch="dev"
      ;;
    refs/heads/main)
      target_branch="main"
      ;;
    *)
      continue
      ;;
  esac

  echo "[pre-push] running build:skills (env: $target_branch)..."
  if bun run build:skills --env="$target_branch"; then
    echo "[pre-push] ✓ build:skills complete"
  else
    echo "[pre-push] ✗ build:skills failed — aborting push" >&2
    exit 1
  fi
done

exit 0
